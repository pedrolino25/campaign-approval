{
  "name": "worklient-api",
  "version": "1.0.0",
  "description": "Worklient API Lambda functions",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "build": "npm run build:lambda",
    "build:lambda": "node build.js",
    "generate:openapi": "tsx scripts/generate-openapi.ts",
    "domain:audit": "tsx scripts/domain-audit.ts",
    "migrate:dev": "dotenv -e .env.dev -- bash scripts/migrate-dev.sh",
    "migrate:prod": "dotenv -e .env.prod -- bash scripts/migrate-prod.sh"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^3.2.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.490.0",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/client-sqs": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "@prisma/client": "^5.7.1",
    "@sendgrid/mail": "^8.1.0",
    "jose": "^6.1.3",
    "path-to-regexp": "^8.2.0",
    "pino": "^8.17.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.130",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "archiver": "^7.0.1",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.19.11",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "eslint-plugin-unused-imports": "^3.0.0",
    "prettier": "^3.1.1",
    "prisma": "^5.7.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
